{
  "name": "Drug Candidate",
  "module": "Pharma RD",
  "doctype": "DocType",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "compound_name",
  "fields": [
    {"fieldname": "section_id",         "fieldtype": "Section Break", "label": "Identification"},
    {"fieldname": "compound_id",        "fieldtype": "Data",    "label": "Compound ID",     "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "compound_name",      "fieldtype": "Data",    "label": "Compound Name",   "reqd": 1, "in_list_view": 1},
    {"fieldname": "iupac_name",         "fieldtype": "Small Text","label": "IUPAC Name"},
    {"fieldname": "col1",               "fieldtype": "Column Break"},
    {"fieldname": "research_project",   "fieldtype": "Link",    "label": "Research Project","options": "Research Project", "in_list_view": 1},
    {"fieldname": "development_stage",  "fieldtype": "Select",  "label": "Development Stage",
      "options": "Hit\nLead\nOptimized Lead\nDevelopment Candidate\nPreclinical\nIND Filed\nClinical\nNDA/BLA Filed\nApproved",
      "in_list_view": 1},
    {"fieldname": "section_chem",       "fieldtype": "Section Break", "label": "Chemical Properties"},
    {"fieldname": "molecular_formula",  "fieldtype": "Data",    "label": "Molecular Formula"},
    {"fieldname": "molecular_weight",   "fieldtype": "Float",   "label": "Molecular Weight (Da)"},
    {"fieldname": "cas_number",         "fieldtype": "Data",    "label": "CAS Number"},
    {"fieldname": "smiles",             "fieldtype": "Small Text","label": "SMILES Notation"},
    {"fieldname": "col2",               "fieldtype": "Column Break"},
    {"fieldname": "logp",               "fieldtype": "Float",   "label": "LogP"},
    {"fieldname": "psa",                "fieldtype": "Float",   "label": "PSA (Å²)"},
    {"fieldname": "hbd",                "fieldtype": "Int",     "label": "H-Bond Donors"},
    {"fieldname": "hba",                "fieldtype": "Int",     "label": "H-Bond Acceptors"},
    {"fieldname": "rotatable_bonds",    "fieldtype": "Int",     "label": "Rotatable Bonds"},
    {"fieldname": "section_bio",        "fieldtype": "Section Break", "label": "Biological Activity"},
    {"fieldname": "target",             "fieldtype": "Link",    "label": "Primary Target",  "options": "Biological Target"},
    {"fieldname": "mechanism_of_action","fieldtype": "Small Text","label": "Mechanism of Action"},
    {"fieldname": "ic50",               "fieldtype": "Float",   "label": "IC50 (nM)"},
    {"fieldname": "ec50",               "fieldtype": "Float",   "label": "EC50 (nM)"},
    {"fieldname": "selectivity_ratio",  "fieldtype": "Float",   "label": "Selectivity Ratio"},
    {"fieldname": "col3",               "fieldtype": "Column Break"},
    {"fieldname": "bioavailability",    "fieldtype": "Percent", "label": "Oral Bioavailability (%)"},
    {"fieldname": "half_life",          "fieldtype": "Float",   "label": "Half-life (h)"},
    {"fieldname": "protein_binding",    "fieldtype": "Percent", "label": "Protein Binding (%)"},
    {"fieldname": "section_safety",     "fieldtype": "Section Break", "label": "Safety Profile"},
    {"fieldname": "ld50",               "fieldtype": "Float",   "label": "LD50 (mg/kg)"},
    {"fieldname": "genotoxicity",       "fieldtype": "Select",  "label": "Genotoxicity",
      "options": "\nPositive\nNegative\nEquivocal"},
    {"fieldname": "herg_inhibition",    "fieldtype": "Select",  "label": "hERG Inhibition",
      "options": "\nHigh\nModerate\nLow\nNegligible"},
    {"fieldname": "safety_notes",       "fieldtype": "Text Editor", "label": "Safety Notes"},
    {"fieldname": "section_ip",         "fieldtype": "Section Break", "label": "IP & Patents"},
    {"fieldname": "patent_status",      "fieldtype": "Select",  "label": "Patent Status",
      "options": "Not Filed\nProvisional Filed\nPCT Filed\nNational Phase\nGranted\nExpired"},
    {"fieldname": "patent_numbers",     "fieldtype": "Small Text","label": "Patent Numbers"},
    {"fieldname": "ip_expiry_date",     "fieldtype": "Date",    "label": "IP Expiry Date"},
    {"fieldname": "amended_from",       "fieldtype": "Link",    "label": "Amended From",    "options": "Drug Candidate", "read_only": 1, "print_hide": 1}
  ],
  "permissions": [
    {"role": "Pharma Admin",      "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
    {"role": "Pharma Researcher", "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "QC Analyst",        "read": 1}
  ]
}
