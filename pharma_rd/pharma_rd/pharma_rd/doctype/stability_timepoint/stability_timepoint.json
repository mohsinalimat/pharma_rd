{
  "name": "Stability Timepoint",
  "module": "Pharma RD",
  "doctype": "DocType",
  "istable": 1,
  "fields": [
    {"fieldname": "timepoint",    "fieldtype": "Data",   "label": "Timepoint",     "reqd": 1, "in_list_view": 1},
    {"fieldname": "target_date",  "fieldtype": "Date",   "label": "Target Date",   "reqd": 1, "in_list_view": 1},
    {"fieldname": "actual_date",  "fieldtype": "Date",   "label": "Actual Date",   "in_list_view": 1},
    {"fieldname": "status",       "fieldtype": "Select", "label": "Status",
      "options": "Pending\nIn Progress\nCompleted\nOverdue\nSkipped", "default": "Pending", "in_list_view": 1},
    {"fieldname": "assay_result", "fieldtype": "Percent","label": "Assay (%)"},
    {"fieldname": "impurity_total","fieldtype": "Percent","label": "Total Impurities (%)"},
    {"fieldname": "appearance",   "fieldtype": "Data",   "label": "Appearance"},
    {"fieldname": "ph",           "fieldtype": "Float",  "label": "pH"},
    {"fieldname": "pass_fail",    "fieldtype": "Select", "label": "Pass/Fail",
      "options": "\nPass\nFail\nConditional Pass", "in_list_view": 1},
    {"fieldname": "remarks",      "fieldtype": "Small Text","label": "Remarks"}
  ]
}
