{
  "name": "Clinical Trial",
  "module": "Pharma RD",
  "doctype": "DocType",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "trial_title",
  "fields": [
    {"fieldname": "section_id",        "fieldtype": "Section Break", "label": "Trial Identification"},
    {"fieldname": "trial_id",          "fieldtype": "Data",    "label": "Trial ID",         "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "trial_title",       "fieldtype": "Data",    "label": "Trial Title",      "reqd": 1},
    {"fieldname": "nct_number",        "fieldtype": "Data",    "label": "ClinicalTrials.gov ID (NCT)"},
    {"fieldname": "col1",              "fieldtype": "Column Break"},
    {"fieldname": "trial_phase",       "fieldtype": "Select",  "label": "Trial Phase",
      "options": "Phase I\nPhase I/II\nPhase II\nPhase II/III\nPhase III\nPhase IV",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "status",            "fieldtype": "Select",  "label": "Status",
      "options": "Draft\nPlanning\nIRB/Ethics Pending\nActive\nEnrollment Complete\nData Collection\nAnalysis\nCompleted\nTerminated\nSuspended",
      "default": "Draft", "in_list_view": 1},
    {"fieldname": "research_project",  "fieldtype": "Link",    "label": "Research Project", "options": "Research Project"},
    {"fieldname": "drug_candidate",    "fieldtype": "Link",    "label": "Drug Candidate",   "options": "Drug Candidate"},
    {"fieldname": "section_design",    "fieldtype": "Section Break", "label": "Study Design"},
    {"fieldname": "study_design",      "fieldtype": "Select",  "label": "Study Design",
      "options": "Randomized Controlled\nOpen Label\nDouble-Blind\nCrossover\nSingle-Arm\nCohort\nCase-Control"},
    {"fieldname": "blinding",          "fieldtype": "Select",  "label": "Blinding",
      "options": "Open Label\nSingle Blind\nDouble Blind\nTriple Blind"},
    {"fieldname": "randomization",     "fieldtype": "Check",   "label": "Randomized"},
    {"fieldname": "col2",              "fieldtype": "Column Break"},
    {"fieldname": "primary_endpoint",  "fieldtype": "Small Text", "label": "Primary Endpoint"},
    {"fieldname": "secondary_endpoints","fieldtype": "Text Editor","label": "Secondary Endpoints"},
    {"fieldname": "target_population", "fieldtype": "Small Text", "label": "Target Population"},
    {"fieldname": "section_enrollment","fieldtype": "Section Break", "label": "Enrollment & Timeline"},
    {"fieldname": "planned_enrollment","fieldtype": "Int",     "label": "Planned Enrollment"},
    {"fieldname": "actual_enrollment", "fieldtype": "Int",     "label": "Actual Enrollment", "read_only": 1},
    {"fieldname": "screen_failures",   "fieldtype": "Int",     "label": "Screen Failures"},
    {"fieldname": "col3",              "fieldtype": "Column Break"},
    {"fieldname": "start_date",        "fieldtype": "Date",    "label": "Start Date"},
    {"fieldname": "primary_completion","fieldtype": "Date",    "label": "Primary Completion Date"},
    {"fieldname": "study_completion",  "fieldtype": "Date",    "label": "Study Completion Date"},
    {"fieldname": "section_sites",     "fieldtype": "Section Break", "label": "Clinical Sites"},
    {"fieldname": "sites",             "fieldtype": "Table",   "label": "Clinical Sites",   "options": "Clinical Trial Site"},
    {"fieldname": "section_safety_mon","fieldtype": "Section Break", "label": "Safety Monitoring"},
    {"fieldname": "irb_approval",      "fieldtype": "Check",   "label": "IRB/Ethics Approved"},
    {"fieldname": "irb_approval_date", "fieldtype": "Date",    "label": "IRB Approval Date"},
    {"fieldname": "irb_number",        "fieldtype": "Data",    "label": "IRB Protocol Number"},
    {"fieldname": "col4",              "fieldtype": "Column Break"},
    {"fieldname": "dsmc",              "fieldtype": "Check",   "label": "DSMC Required"},
    {"fieldname": "interim_analyses",  "fieldtype": "Int",     "label": "Planned Interim Analyses"},
    {"fieldname": "saes",              "fieldtype": "Int",     "label": "Serious Adverse Events"},
    {"fieldname": "amended_from",      "fieldtype": "Link",    "label": "Amended From",    "options": "Clinical Trial", "read_only": 1, "print_hide": 1}
  ],
  "permissions": [
    {"role": "Pharma Admin",              "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
    {"role": "Clinical Trial Manager",    "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Regulatory Affairs Officer","read": 1, "write": 1},
    {"role": "Pharma Researcher",         "read": 1}
  ]
}
