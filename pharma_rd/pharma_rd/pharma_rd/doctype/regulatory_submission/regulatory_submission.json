{
  "name": "Regulatory Submission",
  "module": "Pharma RD",
  "doctype": "DocType",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "submission_id",
  "fields": [
    {"fieldname": "section_id",       "fieldtype": "Section Break", "label": "Submission Details"},
    {"fieldname": "submission_id",    "fieldtype": "Data",    "label": "Submission ID",     "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "research_project", "fieldtype": "Link",    "label": "Research Project",  "options": "Research Project"},
    {"fieldname": "drug_candidate",   "fieldtype": "Link",    "label": "Drug Candidate",    "options": "Drug Candidate", "reqd": 1, "in_list_view": 1},
    {"fieldname": "col1",             "fieldtype": "Column Break"},
    {"fieldname": "submission_type",  "fieldtype": "Select",  "label": "Submission Type",
      "options": "IND\nNDA\nBLA\nANDA\nMAA\nCTA\nIMPD\nDMF\nPre-IND Meeting\nEnd-of-Phase Meeting\nNDA Amendment\nPost-Approval",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "regulatory_agency","fieldtype": "Select",  "label": "Regulatory Agency",
      "options": "FDA\nEMA\nHPRA\nPMDA\nHealth Canada\nTGA\nAnvisa\nCDSCO\nNMPA\nOther",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "status",           "fieldtype": "Select",  "label": "Status",
      "options": "Draft\nInternal Review\nSubmitted\nUnder Review\nAction Required\nApproved\nRejected\nWithdrawn",
      "default": "Draft", "in_list_view": 1},
    {"fieldname": "section_dates",    "fieldtype": "Section Break", "label": "Key Dates"},
    {"fieldname": "planned_submission","fieldtype": "Date",   "label": "Planned Submission Date"},
    {"fieldname": "actual_submission","fieldtype": "Date",    "label": "Actual Submission Date"},
    {"fieldname": "agency_docket",    "fieldtype": "Data",    "label": "Agency Docket Number"},
    {"fieldname": "col2",             "fieldtype": "Column Break"},
    {"fieldname": "pdufa_date",       "fieldtype": "Date",    "label": "PDUFA / Target Action Date"},
    {"fieldname": "decision_date",    "fieldtype": "Date",    "label": "Decision Date"},
    {"fieldname": "approval_number",  "fieldtype": "Data",    "label": "Approval Number"},
    {"fieldname": "section_corr",     "fieldtype": "Section Break", "label": "Agency Correspondence"},
    {"fieldname": "correspondence",   "fieldtype": "Table",   "label": "Correspondence Log",  "options": "Regulatory Correspondence"},
    {"fieldname": "section_notes",    "fieldtype": "Section Break", "label": "Notes"},
    {"fieldname": "regulatory_officer","fieldtype": "Link",   "label": "Regulatory Affairs Officer","options": "User"},
    {"fieldname": "submission_notes", "fieldtype": "Text Editor","label": "Notes & Strategy"},
    {"fieldname": "amended_from",     "fieldtype": "Link",    "label": "Amended From",        "options": "Regulatory Submission", "read_only": 1, "print_hide": 1}
  ],
  "permissions": [
    {"role": "Pharma Admin",              "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
    {"role": "Regulatory Affairs Officer","read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Pharma Researcher",         "read": 1}
  ]
}
