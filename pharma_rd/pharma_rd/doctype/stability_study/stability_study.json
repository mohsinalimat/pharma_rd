{
  "name": "Stability Study",
  "module": "pharma_rd",
  "doctype": "DocType",
  "autoname": "field:study_id",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "study_id",
  "fields": [
    {"fieldname": "section_id",      "fieldtype": "Section Break", "label": "Study Information"},
    {"fieldname": "study_id",        "fieldtype": "Data",    "label": "Study ID",          "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "drug_candidate",  "fieldtype": "Link",    "label": "Drug Candidate",    "options": "Drug Candidate", "reqd": 1, "in_list_view": 1},
    {"fieldname": "batch_no",        "fieldtype": "Link",    "label": "Batch",             "options": "Batch Manufacturing Record"},
    {"fieldname": "research_project","fieldtype": "Link",    "label": "Research Project",  "options": "Research Project"},
    {"fieldname": "col1",            "fieldtype": "Column Break"},
    {"fieldname": "study_type",      "fieldtype": "Select",  "label": "Study Type",
      "options": "Long-Term\nIntermediate\nAccelerated\nStress\nPhoto-stability",
      "reqd": 1, "in_list_view": 1},
    {"fieldname": "status",          "fieldtype": "Select",  "label": "Status",
      "options": "Planned\nOngoing\nCompleted\nCancelled", "default": "Planned", "in_list_view": 1},
    {"fieldname": "ict_guideline",   "fieldtype": "Select",  "label": "ICH Guideline",
      "options": "Q1A(R2)\nQ1B\nQ1C\nQ1D\nQ1E\nQ1F"},
    {"fieldname": "section_cond",    "fieldtype": "Section Break", "label": "Storage Conditions"},
    {"fieldname": "temperature",     "fieldtype": "Data",    "label": "Temperature (°C)",  "in_list_view": 1},
    {"fieldname": "humidity",        "fieldtype": "Data",    "label": "Humidity (%RH)"},
    {"fieldname": "light_condition", "fieldtype": "Select",  "label": "Light Condition",
      "options": "\nProtected from Light\nAmbient Light\nD65 Light"},
    {"fieldname": "col2",            "fieldtype": "Column Break"},
    {"fieldname": "start_date",      "fieldtype": "Date",    "label": "Start Date",        "reqd": 1},
    {"fieldname": "planned_end",     "fieldtype": "Date",    "label": "Planned End Date"},
    {"fieldname": "actual_end",      "fieldtype": "Date",    "label": "Actual End Date"},
    {"fieldname": "section_timepoints","fieldtype": "Section Break", "label": "Timepoints"},
    {"fieldname": "timepoints",      "fieldtype": "Table",   "label": "Stability Timepoints","options": "Stability Timepoint"},
    {"fieldname": "section_conclusion","fieldtype": "Section Break","label": "Conclusion"},
    {"fieldname": "shelf_life_months","fieldtype": "Int",    "label": "Proposed Shelf Life (months)"},
    {"fieldname": "storage_statement","fieldtype": "Small Text","label": "Storage Statement"},
    {"fieldname": "conclusion_notes","fieldtype": "Text Editor","label": "Conclusion / Notes"},
    {"fieldname": "amended_from",    "fieldtype": "Link",    "label": "Amended From",      "options": "Stability Study", "read_only": 1, "print_hide": 1}
  ],
  "permissions": [
    {"role": "Pharma Admin",  "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
    {"role": "QC Analyst",    "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Lab Manager",   "read": 1, "write": 1}
  ]
}
