{
  "name": "R&D Document",
  "module": "pharma_rd",
  "doctype": "DocType",
  "is_submittable": 1,
  "title_field": "document_title",
  "fields": [
    {"fieldname": "document_id",    "fieldtype": "Data",    "label": "Document ID",       "unique": 1, "in_list_view": 1},
    {"fieldname": "document_title", "fieldtype": "Data",    "label": "Document Title",    "reqd": 1, "in_list_view": 1},
    {"fieldname": "document_type",  "fieldtype": "Select",  "label": "Document Type",
      "options": "SOP\nProtocol\nReport\nMethod\nValidation\nRegulatory\nOther", "reqd": 1, "in_list_view": 1},
    {"fieldname": "col1",           "fieldtype": "Column Break"},
    {"fieldname": "version",        "fieldtype": "Data",    "label": "Version",           "reqd": 1, "default": "1.0"},
    {"fieldname": "status",         "fieldtype": "Select",  "label": "Status",
      "options": "Draft\nUnder Review\nApproved\nEffective\nSuperseded\nRetired", "default": "Draft", "in_list_view": 1},
    {"fieldname": "section_lifecycle", "fieldtype": "Section Break", "label": "Lifecycle Dates"},
    {"fieldname": "effective_date", "fieldtype": "Date",    "label": "Effective Date"},
    {"fieldname": "expiry_date",    "fieldtype": "Date",    "label": "Expiry Date"},
    {"fieldname": "review_period",  "fieldtype": "Int",     "label": "Review Period (Months)", "default": 24},
    {"fieldname": "col2",           "fieldtype": "Column Break"},
    {"fieldname": "project",        "fieldtype": "Link",    "label": "Link to Project",   "options": "Research Project"},
    {"fieldname": "department",     "fieldtype": "Data",    "label": "Department"},
    {"fieldname": "section_file",   "fieldtype": "Section Break", "label": "File Attachment"},
    {"fieldname": "file_attachment","fieldtype": "Attach",  "label": "Attach Document"},
    {"fieldname": "summary",        "fieldtype": "Small Text","label": "Summary of Changes"},
    {"fieldname": "amended_from",   "fieldtype": "Link",    "label": "Amended From",      "options": "R&D Document", "read_only": 1, "print_hide": 1}
  ],
  "permissions": [
    {"role": "Pharma Admin", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
    {"role": "Pharma Researcher", "read": 1, "write": 1, "create": 1, "submit": 1}
  ]
}
