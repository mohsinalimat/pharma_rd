{
  "name": "Research Project",
  "module": "Pharma R&D",
  "doctype": "DocType",
  "is_submittable": 1,
  "track_changes": 1,
  "title_field": "project_title",
  "search_fields": "project_code,project_title,therapeutic_area",
  "fields": [
    {"fieldname": "section_basic", "fieldtype": "Section Break", "label": "Project Information"},
    {"fieldname": "project_code",  "fieldtype": "Data",          "label": "Project Code",        "reqd": 1, "unique": 1, "in_list_view": 1},
    {"fieldname": "project_title", "fieldtype": "Data",          "label": "Project Title",       "reqd": 1, "in_list_view": 1},
    {"fieldname": "col1",          "fieldtype": "Column Break"},
    {"fieldname": "status",        "fieldtype": "Select",         "label": "Status",
      "options": "Draft\nActive\nOn Hold\nCompleted\nCancelled",  "default": "Draft", "in_list_view": 1},
    {"fieldname": "priority",      "fieldtype": "Select",         "label": "Priority",
      "options": "Low\nMedium\nHigh\nCritical", "default": "Medium"},
    {"fieldname": "section_details", "fieldtype": "Section Break", "label": "Scientific Details"},
    {"fieldname": "therapeutic_area","fieldtype": "Link",   "label": "Therapeutic Area",  "options": "Therapeutic Area", "reqd": 1},
    {"fieldname": "drug_modality",   "fieldtype": "Select", "label": "Drug Modality",
      "options": "Small Molecule\nBiologic\nCell Therapy\nGene Therapy\nVaccine\nOligonucleotide\nAntibody\nOther"},
    {"fieldname": "col2",            "fieldtype": "Column Break"},
    {"fieldname": "research_phase",  "fieldtype": "Select", "label": "Research Phase",
      "options": "Target Identification\nTarget Validation\nHit Identification\nHit-to-Lead\nLead Optimization\nPreclinical\nPhase I\nPhase II\nPhase III\nRegistration\nPost-Market"},
    {"fieldname": "indication",      "fieldtype": "Small Text", "label": "Indication / Disease Area"},
    {"fieldname": "section_team",    "fieldtype": "Section Break", "label": "Team & Budget"},
    {"fieldname": "principal_investigator", "fieldtype": "Link",  "label": "Principal Investigator", "options": "User", "reqd": 1},
    {"fieldname": "project_manager",        "fieldtype": "Link",  "label": "Project Manager",        "options": "User"},
    {"fieldname": "department",             "fieldtype": "Data",  "label": "Department"},
    {"fieldname": "col3",                   "fieldtype": "Column Break"},
    {"fieldname": "start_date",  "fieldtype": "Date",    "label": "Start Date",  "reqd": 1},
    {"fieldname": "end_date",    "fieldtype": "Date",    "label": "Target End Date"},
    {"fieldname": "budget",      "fieldtype": "Currency","label": "Total Budget"},
    {"fieldname": "spent_budget","fieldtype": "Currency","label": "Spent Budget", "read_only": 1},
    {"fieldname": "section_team_members", "fieldtype": "Section Break", "label": "Team Members"},
    {"fieldname": "team_members", "fieldtype": "Table", "label": "Team Members", "options": "Research Project Team Member"},
    {"fieldname": "section_milestones", "fieldtype": "Section Break", "label": "Milestones"},
    {"fieldname": "milestones", "fieldtype": "Table", "label": "Milestones", "options": "Research Project Milestone"},
    {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes & Attachments"},
    {"fieldname": "objectives",    "fieldtype": "Text Editor", "label": "Project Objectives"},
    {"fieldname": "background",    "fieldtype": "Text Editor", "label": "Scientific Background"},
    {"fieldname": "amended_from",  "fieldtype": "Link", "label": "Amended From", "options": "Research Project", "read_only": 1, "print_hide": 1}
  ],
  "permissions": [
    {"role": "Pharma Admin",       "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 1, "cancel": 1, "amend": 1},
    {"role": "Pharma Researcher",  "read": 1, "write": 1, "create": 1, "submit": 1},
    {"role": "Lab Manager",        "read": 1, "write": 1}
  ],
  "links": [
    {"link_doctype": "Drug Candidate",         "link_fieldname": "research_project"},
    {"link_doctype": "Clinical Trial",         "link_fieldname": "research_project"},
    {"link_doctype": "Stability Study",        "link_fieldname": "research_project"},
    {"link_doctype": "Regulatory Submission",  "link_fieldname": "research_project"}
  ]
}
